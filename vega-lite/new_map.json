{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "width": 800,
  "height": 500,

  "projection": {
    "type": "equalEarth"
  },

  "data": {
    "url": "https://raw.githubusercontent.com/vega/vega/main/docs/data/world-110m.json",

    "format": {
      "type": "topojson",
      "feature": "countries"
    }
  },

  "mark": {
    "type": "geoshape",
    "fill": "lightgray",
    "stroke": "white"
  }
}