{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Median Household Income by Malaysian State",
  "width": 970,
  "height": 500,
  "params": [
    {
      "name": "Year",
      "value": 2024,
      "bind": {
        "input": "select",
        "options": [2019, 2022, 2024],
        "name": "Select Year: "
      }
    }
  ],
"projection": {
  "type": "mercator"
},
  "data": {
    "url": "https://raw.githubusercontent.com/gxtan/FIT2179-DV2/main/data/sec1_c1_data.csv",
    "format": {
      "type": "csv",
      "parse": {
        "date": "number",
        "income": "number"
      }
    }
  },
  "transform": [
    {
      "filter": "datum.date == Year"
    },
    {
      "lookup": "state",
      "from": {
        "data": {
          "url": "https://raw.githubusercontent.com/gxtan/FIT2179-DV2/main/data/malaysia_state.topojson",
          "format": {
            "type": "topojson",
            "feature": "states"
          }
        },
        "key": "properties.Name"
      },
      "as": "geo"
    }
  ],
  "mark": {
    "type": "geoshape",
    "stroke": "white",
    "strokeWidth": 1
  },
  "encoding": {
    "shape": {
      "field": "geo",
      "type": "geojson"
    },
    "color": {
      "field": "income",
      "type": "quantitative",
      "scale": {
        "scheme": "blues"
      },
      "title": "Median Income (RM)"
    },
    "tooltip": [
      {
        "field": "state",
        "type": "nominal",
        "title": "State"
      },
      {
        "field": "date",
        "type": "quantitative",
        "title": "Year"
      },
      {
        "field": "income",
        "type": "quantitative",
        "format": ",",
        "title": "Income (RM)"
      }
    ]
  }
}