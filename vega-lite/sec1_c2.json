{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "title": "Monthly Household Mean Income By States",

  "width": 500,
  "height": 200,

  "data": {
    "url": "../data/sec1_c2_data.csv"
  },

  "transform": [

    {
      "filter": "datum.variable == 'mean'"
    },

    {
      "aggregate": [
        {
          "op": "mean",
          "field": "income",
          "as": "mean_income"
        }
      ],
      "groupby": ["state"]
    },

    {
      "window": [
        {
          "op": "rank",
          "as": "rank"
        }
      ],

      "sort": [
        {
          "field": "mean_income",
          "order": "descending"
        }
      ]
    }

  ],

  "mark": {
    "type": "bar",
    "cornerRadiusEnd": 3
  },

  "encoding": {

    "y": {
      "field": "state",
      "type": "nominal",
      "sort": "-x",
      "title": "State"
    },

    "x": {
      "field": "mean_income",
      "type": "quantitative",
      "title": "Income (RM)"
    },

    "color": {
      "condition": {
        "test": "datum.rank == 1",
        "value": "#08306b"
      },
      "value": "#d9d9d9"
    },

    "tooltip": [
      {
        "field": "state",
        "type": "nominal",
        "title": "State"
      },
      {
        "field": "mean_income",
        "type": "quantitative",
        "title": "Mean Income"
      }
    ]
  },

  "config": {

    "view": {
      "stroke": null
    },

    "axis": {
      "labelFontSize": 12,
      "titleFontSize": 14
    }
  }
}