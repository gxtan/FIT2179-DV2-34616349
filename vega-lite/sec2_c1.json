{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Dumbbell chart showing the 99th percentile income range by state for 2024.",
  "data": {
    "url": "../data/sec2_c1_data.csv"
  },
  "transform": [
    {
      "filter": "datum.date == 2024"
    }
  ],
  "width": 980,
  "height": 400,
  "encoding": {
    "y": {
      "field": "state",
      "type": "nominal",
      "title": "State",
      "sort": {"field": "income", "op": "max", "order": "descending"}
    }
  },
  "layer": [
    {
      "description": "Connecting line between min and max",
      "mark": "rule",
      "encoding": {
        "x": {
          "field": "income",
          "type": "quantitative",
          "aggregate": "min",
          "title": "Median Monthly Income (RM)"
        },
        "x2": {
          "field": "income",
          "aggregate": "max"
        },
        "color": {"value": "#dbdbdb"}
      }
    },
    {
      "description": "Dumbbell endpoints",
      "mark": {"type": "point", "size": 80, "filled": true, "opacity": 1},
      "encoding": {
        "x": {
          "field": "income",
          "type": "quantitative"
        },
        "color": {
          "field": "variable",
          "type": "nominal",
          "legend": null,
          "scale": {
            "domain": ["minimum", "maximum"],
            "range": ["#1f77b4", "#ff7f0e"]
          }
        },
        "tooltip": [
          {"field": "state", "type": "nominal", "title": "State"},
          {"field": "variable", "type": "nominal", "title": "Type"},
          {"field": "income", "type": "quantitative", "title": "Income", "format": ","}
        ]
      }
    }
  ]
}