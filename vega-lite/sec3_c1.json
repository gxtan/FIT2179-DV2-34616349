{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Monthly Household Income to Percentile Distribution",

  "data": {
    "url": "https://raw.githubusercontent.com/gxtan/FIT2179-DV2/main/data/sec3_data.csv"
  },

  "transform": [
    {
      "filter": "datum.date == 2024"
    },
    {
      "filter": "datum.variable == 'median'"
    }
  ],

  "width": 970,
  "height": 400,

  "mark": {
    "type": "area",
    "interpolate": "monotone",
    "color": "#f46d43",
    "opacity": 0.85
  },

  "encoding": {
    "x": {
      "field": "percentile",
      "type": "quantitative",
      "title": "% of Population (Percentile)",
      "scale": { "domain": [1, 100] },
      "axis": {
        "format": ".0f",
        "labelExpr": "datum.value + '%'"
      }
    },

    "y": {
      "field": "income",
      "type": "quantitative",
      "title": "Monthly Household Income (RM)",
      "scale": { "zero": false }
    },

    "tooltip": [
      {
        "field": "percentile",
        "type": "quantitative",
        "title": "Percentile",
        "format": ".0f"
      },
      {
        "field": "income",
        "type": "quantitative",
        "title": "Income (RM)"
      }
    ]
  },

  "config": {
    "view": { "stroke": null },
    "background": "white"
  }
}