{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "GDP Heatmap by State and Sector (2023)",
  "data": {
    "url": "https://raw.githubusercontent.com/gxtan/FIT2179-DV2/main/data/sec4_c1_data.csv"
  },

  "transform": [
    {
      "filter": "datum.date == 2023"
    },
    {
      "calculate": "log(datum.value + 1)",
      "as": "value_log"
    },
    {
      "calculate": "datum.sector == 'p0' ? 'Overall GDP' : datum.sector == 'p1' ? 'Agriculture' : datum.sector == 'p2' ? 'Mining & Quarrying' : datum.sector == 'p3' ? 'Manufacturing' : datum.sector == 'p4' ? 'Construction' : datum.sector == 'p5' ? 'Services' : datum.sector == 'p6' ? 'Import Duties' : datum.sector",
      "as": "sector_name"
    }
  ],

  "mark": {
    "type": "rect"
  },

  "encoding": {
    "x": {
      "field": "state",
      "type": "nominal",
      "title": "State",
      "axis": {
        "labelAngle": -30
      }
    },

    "y": {
      "field": "sector_name",
      "type": "nominal",
      "title": "Sector",
      "sort": [
        "Overall GDP",
        "Agriculture",
        "Mining & Quarrying",
        "Manufacturing",
        "Construction",
        "Services",
        "Import Duties"
      ]
    },

    "color": {
      "field": "value_log",
      "type": "quantitative",
      "title": "GDP Value",
      "scale": {
        "scheme": "inferno"
      }
    },

    "tooltip": [
      {
        "field": "state",
        "type": "nominal",
        "title": "State"
      },
      {
        "field": "sector_name",
        "type": "nominal",
        "title": "Sector"
      },
      {
        "field": "value",
        "type": "quantitative",
        "title": "GDP Value",
        "format": ","
      }
    ]
  },

  "config": {
    "view": {
      "stroke": null
    }
  }
}