{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "title": "Malaysia Total GDP by State",

  "width": 970,
  "height": 500,

  "params": [
    {
      "name": "Year",
      "value": 2023,
      "bind": {
        "input": "range",
        "min": 2015,
        "max": 2023,
        "step": 1,
        "name": "Select Year: "
      }
    }
  ],

  "projection": {
    "type": "mercator"
  },

  "data": {
    "url": "../data/sec4_c2_data.csv",
    "format": {
      "type": "csv",
      "parse": {
        "date": "number",
        "total gdp": "number"
      }
    }
  },

  "transform": [
    {
      "filter": "datum.date == Year"
    },
    {
      "lookup": "state",
      "from": {
        "data": {
          "url": "https://raw.githubusercontent.com/gxtan/FIT2179-DV2/main/data/malaysia_state.topojson",
          "format": {
            "type": "topojson",
            "feature": "states"
          }
        },
        "key": "properties.Name"
      },
      "as": "geo"
    }
  ],

  "mark": {
    "type": "geoshape",
    "stroke": "white",
    "strokeWidth": 1
  },

  "encoding": {
    "shape": {
      "field": "geo",
      "type": "geojson"
    },

    "color": {
      "field": "total gdp",
      "type": "quantitative",
      "title": "Total GDP (RM million)",
      "scale": {
        "scheme": "blues",
        "type": "quantile",
        "n": 5
      }
    },

    "tooltip": [
      { "field": "state", "type": "nominal", "title": "State" },
      { "field": "date", "type": "quantitative", "title": "Year" },
      {
        "field": "total gdp",
        "type": "quantitative",
        "format": ",.2f",
        "title": "Total GDP"
      }
    ]
  }
}