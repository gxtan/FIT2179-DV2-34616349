{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Total GDP by Malaysian State",
  "width": 980,
  "height": 500,

  "projection": {
    "type": "mercator"
  },

  "data": {
    "url": "https://raw.githubusercontent.com/gxtan/FIT2179-DV2/main/data/sec4_c2_data.csv",
    "format": {
      "type": "csv"
    }
  },

  "transform": [
    {
      "lookup": "state",
      "from": {
        "data": {
          "url": "https://raw.githubusercontent.com/gxtan/FIT2179-DV2/main/data/malaysia_state.topojson",
          "format": {
            "type": "topojson",
            "feature": "states"
          }
        },
        "key": "properties.Name"
      },
      "as": "geo"
    }
  ],

  "mark": {
    "type": "geoshape",
    "stroke": "white",
    "strokeWidth": 1
  },

  "encoding": {

    "shape": {
      "field": "geo",
      "type": "geojson"
    },

    "color": {
      "field": "total gdp",
      "type": "quantitative",

      "scale": {
        "type": "log",
        "scheme": "blues"
      },

      "title": "Total GDP"
    },

    "tooltip": [
      {
        "field": "state",
        "type": "nominal",
        "title": "State"
      },
      {
        "field": "total gdp",
        "type": "quantitative",
        "format": ",.0f",
        "title": "Total GDP"
      }
    ]
  }
}